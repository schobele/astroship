---
import Container from "@/components/container.astro";
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Seite nicht gefunden">
  <Container>
    <div class="flex min-h-[60vh] flex-col items-center justify-center py-24 text-center">
      <span class="font-display text-xs uppercase tracking-[0.22em] text-accent">Fehler 404</span>
      <h1 class="font-display mt-6 text-balance text-5xl font-medium leading-[1.05] tracking-tight text-foreground md:text-7xl">
        Diese Seite haben wir leider nicht gefunden.
      </h1>
      <p class="mt-6 max-w-md text-pretty text-base leading-relaxed text-muted-foreground">
        Vielleicht haben wir sie umgebaut. Kein Problem — von hier aus geht es zurück.
      </p>
      <a
        href="/"
        class="mt-10 inline-flex items-center gap-2 rounded-sm bg-primary px-6 py-3 text-sm font-medium text-primary-foreground transition hover:bg-foreground"
      >
        Zur Startseite <span aria-hidden="true">→</span>
      </a>
    </div>
  </Container>
</Layout>
