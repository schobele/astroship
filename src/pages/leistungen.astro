---
import Container from "@/components/container.astro";
import Layout from "@/layouts/Layout.astro";

const services = [
  {
    id: "badsanierung",
    no: "01",
    title: "Badsanierung",
    lead: "Modern & innovativ. Das Bad als Ruhepol und Wellnessoase Ihres Zuhauses.",
    image: "/images/hero-bathroom.jpg",
    imageAlt: "Modernes Badezimmer mit freistehender Wanne",
    body: "Wir sanieren Ihr Bad vollständig aus einer Hand — vom Abriss bis zur fertigen Fuge. Sie haben einen Ansprechpartner, eine saubere Baustelle und ein verbindliches Festpreisangebot.",
    points: [
      "Komplette Badsanierung in Festpreis",
      "Barrierearme & altersgerechte Lösungen",
      "Walk-In-Duschen, freistehende Wannen",
      "Hochwertige Markenhersteller",
    ],
  },
  {
    id: "heizungsbau",
    no: "02",
    title: "Heizungsbau",
    lead: "Effizient, leise, zukunftssicher. Für Fußbodenheizung sind wir Ihr bester Ansprechpartner.",
    image: "/images/service-heating.jpg",
    imageAlt: "Moderner Heizkörper an einer Lehmwand",
    body: "Ob neue Wärmepumpe, klassische Gasbrennwerttechnik oder Fußbodenheizung in der Sanierung — wir beraten herstellerunabhängig und installieren mit Meisterhand.",
    points: [
      "Wärmepumpen & Hybridanlagen",
      "Brennwerttechnik",
      "Fußbodenheizung — auch nachträglich",
      "Hydraulischer Abgleich & Wartung",
    ],
  },
  {
    id: "solar",
    no: "03",
    title: "Solar",
    lead: "Solaranlagen gehören zu unserem Repertoire — mit freier Energie vom Dach.",
    image: "/images/service-solar.jpg",
    imageAlt: "Solarthermie-Anlage auf einem roten Ziegeldach",
    body: "Wir planen und installieren Solarthermie-Anlagen für Warmwasser und Heizungsunterstützung. Klimafreundlich, langlebig und perfekt aufeinander abgestimmt mit Ihrer Heizung.",
    points: [
      "Solarthermie für Warmwasser",
      "Heizungsunterstützung",
      "Speicherlösungen",
      "Förderberatung",
    ],
  },
  {
    id: "wasser",
    no: "04",
    title: "Wasseraufbereitung",
    lead: "Wasserqualität mit Wasseraufbereitung von Ihrem Meisterbetrieb Hungerland.",
    image: "/images/service-water.jpg",
    imageAlt: "Klares Wasser aus einem Designer-Wasserhahn",
    body: "Sauberes, weiches Wasser schützt Ihre Leitungen, Ihre Geräte und Ihr Wohlbefinden. Wir analysieren Ihr Wasser und finden gemeinsam die passende Lösung.",
    points: [
      "Enthärtungsanlagen",
      "Filtrationssysteme",
      "Trinkwasseranalyse",
      "Wartung & Service",
    ],
  },
];
---

<Layout title="Leistungen" description="Badsanierung, Heizungsbau, Solar und Wasseraufbereitung aus Meisterhand. Alle Leistungen von Thorsten Hungerland Sanitär- und Heizungstechnik in Springe.">
  {/* Hero */}
  <section class="border-b border-border">
    <Container>
      <div class="grid gap-10 py-20 md:grid-cols-12 md:py-28">
        <div class="md:col-span-5">
          <div class="flex items-center gap-3">
            <span class="h-px w-10 bg-accent"></span>
            <span class="text-xs uppercase tracking-[0.22em] text-muted-foreground">Leistungen</span>
          </div>
          <h1 class="font-display mt-5 text-balance text-5xl font-medium leading-[1.02] tracking-tight text-foreground md:text-6xl">
            Vier Gewerke. Aus Meisterhand.
          </h1>
        </div>
        <div class="md:col-span-7 md:pl-10">
          <p class="text-pretty text-lg leading-relaxed text-muted-foreground">
            Wir als Meisterbetrieb bieten Ihnen einen umfassenden Service — von der ersten
            Beratung bis zur regelmäßigen Wartung. Für Heizungsbau und Heizungstechnik in
            Springe, Hameln, Hildesheim und Laatzen sind wir Ihr Experte.
          </p>
          <div class="mt-10 flex flex-wrap gap-2">
            {services.map((s) => (
              <a
                href={`#${s.id}`}
                class="inline-flex items-center gap-2 rounded-full border border-border px-4 py-1.5 text-xs uppercase tracking-[0.18em] text-muted-foreground transition hover:border-foreground hover:text-foreground"
              >
                <span class="text-accent">{s.no}</span>
                {s.title}
              </a>
            ))}
          </div>
        </div>
      </div>
    </Container>
  </section>

  {/* Services list — alternating */}
  {services.map((s, i) => (
    <section id={s.id} class:list={["border-b border-border", i % 2 === 1 && "bg-surface"]}>
      <Container>
        <div class:list={["grid gap-12 py-24 md:grid-cols-12 md:gap-16 md:py-32"]}>
          <div class:list={["md:col-span-6", i % 2 === 1 && "md:order-2"]}>
            <div class="aspect-[4/5] overflow-hidden rounded-sm bg-muted">
              <img src={s.image} alt={s.imageAlt} class="h-full w-full object-cover" loading="lazy" />
            </div>
          </div>
          <div class:list={["flex flex-col justify-center md:col-span-6", i % 2 === 1 && "md:order-1"]}>
            <span class="font-display text-xs uppercase tracking-[0.22em] text-accent">{s.no} / {String(services.length).padStart(2, "0")}</span>
            <h2 class="font-display mt-4 text-balance text-4xl font-medium leading-[1.05] tracking-tight text-foreground md:text-5xl">
              {s.title}
            </h2>
            <p class="font-display mt-6 text-pretty text-xl leading-[1.4] text-foreground/80">
              {s.lead}
            </p>
            <p class="mt-5 text-pretty text-base leading-relaxed text-muted-foreground">
              {s.body}
            </p>
            <ul class="mt-10 grid grid-cols-1 gap-3 sm:grid-cols-2">
              {s.points.map((p) => (
                <li class="flex items-start gap-3 border-t border-border pt-3 text-sm text-foreground">
                  <span aria-hidden="true" class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
                  {p}
                </li>
              ))}
            </ul>
            <div class="mt-10">
              <a
                href="/kontakt"
                class="inline-flex items-center gap-2 text-sm font-medium text-foreground hover:text-accent"
              >
                Anfrage zu {s.title} <span aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        </div>
      </Container>
    </section>
  ))}

  {/* Service overview */}
  <section class="py-24 md:py-32">
    <Container>
      <div class="grid gap-10 md:grid-cols-12">
        <div class="md:col-span-4">
          <span class="text-xs uppercase tracking-[0.22em] text-muted-foreground">Unser Service im Überblick</span>
          <h2 class="font-display mt-5 text-balance text-3xl font-medium leading-[1.1] tracking-tight text-foreground md:text-4xl">
            Rundum-Service — wie man ihn vom guten Handwerk erwartet.
          </h2>
        </div>
        <ul class="md:col-span-8 grid grid-cols-1 gap-x-10 gap-y-4 sm:grid-cols-2">
          {[
            "Beratung vor Ort",
            "Aufmaß",
            "3-D-Badplanung",
            "Badkonfigurator",
            "Badplanung mit fachgerechter Handzeichnung",
            "Checklisten für eine Kostenkalkulation",
            "Finanzierung",
            "Montage",
            "Rundum-Service nach dem Kauf",
            "Notdienst für Heizung und Bad",
            "Wartung von Heizungs- und Sanitäranlagen",
            "Modernisierung im Bestand",
          ].map((item) => (
            <li class="flex items-baseline gap-4 border-t border-border py-4 text-base text-foreground">
              <span class="font-display text-xs text-accent">▸</span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </Container>
  </section>
</Layout>
