---
import Container from "@/components/container.astro";
import Layout from "@/layouts/Layout.astro";

const phases = [
  { no: "01", title: "Inspiration im Badstudio", desc: "Anfassen, ausprobieren, vergleichen. In unserem großzügigen Studio finden Sie alles, was ein gutes Bad ausmacht." },
  { no: "02", title: "Beratung & Aufmaß", desc: "Wir kommen zu Ihnen, hören zu und nehmen alles auf — Maße, Wünsche, Stil und Budget." },
  { no: "03", title: "Handzeichnung & 3-D-Planung", desc: "Wir zeigen Ihr neues Bad fachgerecht skizziert und in fotorealistischer 3-D-Ansicht — bevor ein einziger Hammer fällt." },
  { no: "04", title: "Festpreis & Termin", desc: "Klare Kostenkalkulation, klare Termine, eine saubere Baustelle. Versprochen." },
  { no: "05", title: "Montage durch Meisterhand", desc: "Ein eingespieltes Team setzt Ihre Planung präzise um — von Sanitär über Heizung bis Fliese." },
  { no: "06", title: "Übergabe & Service", desc: "Ausführliche Einweisung, transparente Dokumentation und ein Ansprechpartner für später." },
];

const partners = [
  "Villeroy & Boch",
  "Duravit",
  "Hansgrohe",
  "Grohe",
  "Geberit",
  "Kaldewei",
  "Keuco",
  "Vaillant",
  "Viessmann",
  "Buderus",
];
---

<Layout title="Badplanung" description="Badplanung & Sanitärinstallation mit 3-D-Planung, fachgerechter Handzeichnung und großzügigem Badstudio. Thorsten Hungerland in Springe.">
  {/* Hero */}
  <section class="border-b border-border">
    <Container>
      <div class="grid gap-10 py-20 md:grid-cols-12 md:py-28">
        <div class="md:col-span-7">
          <div class="flex items-center gap-3">
            <span class="h-px w-10 bg-accent"></span>
            <span class="text-xs uppercase tracking-[0.22em] text-muted-foreground">Badplanung &amp; Sanitärinstallation</span>
          </div>
          <h1 class="font-display mt-6 text-balance text-5xl font-medium leading-[1.02] tracking-tight text-foreground md:text-7xl">
            Ihr neues Bad — individuell entworfen, präzise gebaut.
          </h1>
        </div>
        <div class="md:col-span-5 md:pt-2">
          <p class="text-pretty text-lg leading-relaxed text-muted-foreground">
            Lassen Sie sich von unserem großzügigen Badstudio inspirieren. Wir sind Ihr
            Experte für Badplanung, Gestaltung und Umsetzung — und verwirklichen Ihr
            Bauprojekt von der ersten Idee bis zur Übergabe.
          </p>
          <a
            href="/kontakt"
            class="mt-8 inline-flex items-center gap-2 rounded-sm bg-primary px-6 py-3.5 text-sm font-medium text-primary-foreground transition hover:bg-foreground"
          >
            Termin im Badstudio <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </Container>
  </section>

  {/* Big image */}
  <section class="border-b border-border bg-surface">
    <Container>
      <div class="py-16 md:py-24">
        <div class="aspect-[16/9] w-full overflow-hidden rounded-sm bg-muted">
          <img
            src="/images/bath-studio.jpg"
            alt="Großzügiges Badstudio mit Ausstellungsstücken"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </Container>
  </section>

  {/* Phases */}
  <section class="py-24 md:py-32">
    <Container>
      <div class="grid gap-10 md:grid-cols-12">
        <div class="md:col-span-4">
          <span class="text-xs uppercase tracking-[0.22em] text-muted-foreground">In 6 Schritten</span>
          <h2 class="font-display mt-5 text-balance text-4xl font-medium leading-[1.05] tracking-tight text-foreground md:text-5xl">
            Von der Idee zum fertigen Bad.
          </h2>
          <p class="mt-6 max-w-md text-pretty text-base leading-relaxed text-muted-foreground">
            Eine gute Badplanung beginnt mit Zuhören. Unser Prozess ist klar strukturiert,
            damit Sie jederzeit wissen, wo Ihr Projekt steht.
          </p>
        </div>

        <ol class="md:col-span-8 grid gap-px overflow-hidden border border-border bg-border sm:grid-cols-2">
          {phases.map((p) => (
            <li class="flex flex-col bg-background p-8">
              <span class="font-display text-xs uppercase tracking-[0.22em] text-accent">{p.no}</span>
              <h3 class="font-display mt-5 text-xl tracking-tight text-foreground">{p.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{p.desc}</p>
            </li>
          ))}
        </ol>
      </div>
    </Container>
  </section>

  {/* Partners */}
  <section class="border-y border-border bg-surface py-20">
    <Container>
      <div class="grid gap-8 md:grid-cols-12 md:items-end">
        <div class="md:col-span-5">
          <span class="text-xs uppercase tracking-[0.22em] text-muted-foreground">Unsere Hersteller</span>
          <h2 class="font-display mt-5 text-balance text-3xl font-medium leading-[1.1] tracking-tight text-foreground md:text-4xl">
            Attraktive Designs, beste Funktion und Verarbeitung.
          </h2>
        </div>
        <p class="md:col-span-7 text-pretty text-base leading-relaxed text-muted-foreground">
          Wir arbeiten herstellerunabhängig und kombinieren das, was wirklich zu Ihnen passt —
          aus Qualitätsprodukten renommierter deutscher und europäischer Marken.
        </p>
      </div>

      <ul class="mt-12 grid grid-cols-2 gap-px overflow-hidden border border-border bg-border sm:grid-cols-3 md:grid-cols-5">
        {partners.map((p) => (
          <li class="flex items-center justify-center bg-surface px-4 py-8 text-center">
            <span class="font-display text-base tracking-tight text-foreground/80">{p}</span>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  {/* CTA */}
  <section class="py-24 md:py-32">
    <Container>
      <div class="grid gap-10 md:grid-cols-12 md:items-end">
        <div class="md:col-span-8">
          <div class="flex items-center gap-3">
            <span class="h-px w-10 bg-accent"></span>
            <span class="text-xs uppercase tracking-[0.22em] text-muted-foreground">Lassen Sie sich vom Profi beraten</span>
          </div>
          <h2 class="font-display mt-5 text-balance text-5xl font-medium leading-[1.02] tracking-tight text-foreground md:text-6xl">
            Wir planen mit Ihnen Ihr neues Bad — ganz individuell.
          </h2>
        </div>
        <div class="md:col-span-4 md:text-right">
          <a
            href="/kontakt"
            class="inline-flex items-center justify-center gap-2 rounded-sm bg-primary px-7 py-4 text-sm font-medium text-primary-foreground transition hover:bg-foreground"
          >
            Beratungstermin anfragen <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </Container>
  </section>
</Layout>
